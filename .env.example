# .env.example — template for environment variables in local development
# Copy these into Vercel Dashboard → Project → Settings → Environment Variables

# Your application environment (e.g. development, production)
VITE_APP_ENV=development

# OpenAI API key for AI-assisted sheet column mapping
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Optional: Database connection strings (used for backend server-side imports only)
# DB_MYSQL_URL=mysql://user:pass@host:3306/dbname
# DB_POSTGRES_URL=postgresql://user:pass@host:5432/dbname
# DB_SQLITE_PATH=./backend/data/commerceflow.db

# NOTE: WooCommerce and Shopify API keys should NOT be placed in environment files.
# They are gathered dynamically per-request from user input in the frontend UI.
